{
  "sway/workspaces": {
    "all-outputs": false,
    "disable-scroll": false,
    "format": "{icon}  {name}",
    "format-icons": {
      "1:term": "",
      "2:dev": "",
      "3:web": "",
      "4:mail": "󰇮",
      "5:message": "",
      "6:spotify": "",
      "8:docker": "",
      "9:passwords": "",
      "10:zoom": "",
      "default": "󰌽"
    }
  },
  "sway/language": {
    "format": "  {short}",
    "min-length": 5,
    "tooltip": false,
    "on-click": "swaymsg input $(swaymsg -t get_inputs --raw | jq '[.[] | select(.type == \"keyboard\")][0] | .identifier') xkb_switch_layout next"
  },
  "sway/mode": {
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "format": "<span style=\"italic\">{text}</span>",
{% else %}
    "format": "<span style=\"italic\">{}</span>",
{% endif %}
    "tooltip": false
  },
  "sway/window": {
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "format": "{text}",
{% else %}
    "format": "{}",
{% endif %}
    "max-length": 50,
    "tooltip": true
  },
  "sway/scratchpad": {
    "format": "{icon} {count}",
    "show-empty": false,
    "format-icons": ["", " "],
    "tooltip": true,
    "tooltip-format": "{app}: {title}"
  },
  "custom/sunset": {
    "interval": "once",
    "tooltip": true,
    "return-type": "json",
    "format": "{icon}",
    "format-icons": {
      "activated": "󰌵",
      "deactivated": "󰌶"
    },
    "exec": "~/.config/waybar/scripts/sunset.sh",
    "on-click": "~/.config/waybar/scripts/sunset.sh toggle",
    "exec-if": "~/.config/waybar/scripts/sunset.sh check",
    "signal": 6
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon}  {percent:>3}%",
    "format-icons": ["󰹐", "󱩎", "󱩏", "󱩐", "󱩑", "󱩒", "󱩓", "󱩔", "󱩕", "󱩖", "󰛨"],
{% if waybar_current_version.split('.') | map('int') | list >= [0, 9, 18] %}
    "scroll-step": 5.0,
{% else %}
    "on-scroll-down": "brightnessctl --quiet set 5%-",
    "on-scroll-up": "brightnessctl --quiet set 5%+"
{% endif %}
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "min-brightness": 5.0,
{% endif %}
  },
  "pulseaudio": {
    "format": "{icon} {volume:>3}% {format_source}",
    "format-bluetooth": "{icon} {volume:>3}%",
    "format-muted": " mute {format_source}",
    "format-source": " {volume:>3}%",
    "format-source-muted": " mute",
    "format-icons": {
      "headphone": "",
      "alsa_output.usb-Kingston_HyperX_Virtual_Surround_Sound_00000000-00.analog-stereo": "󰋎",
      "alsa_output.usb-Kingston_HyperX_Cloud_II_Wireless_000000000001-00.analog-surround-71": "󰋎",
      "default": ["", "", ""]
    },
    "tooltip-format": "{desc}: {volume}% {format_source}",
    "on-click": "swaymsg exec '$volume_mute'",
    "on-click-right": "swaymsg exec 'pavucontrol'"
  },
{% for interface in ansible_facts | dict2items | selectattr('value.module', 'defined') | map(attribute='value') | list | sort(attribute='device') %}
  "network#{{ interface.device }}": {
    "interface": "{{ interface.device }}",
    "format-wifi": "{icon}  {ifname}: {ipaddr}",
    "format-ethernet": "  {ifname}: {ipaddr}",
    "format-disconnected": "  {ifname}",
    "tooltip-format-wifi": "Connected on {essid} (Freq: {frequency})\nSignal: {signalStrength}\n\n󰩟  {ipaddr}\n󱀣  {netmask} ({cidr})\n\nUp: {bandwidthUpOctets}\nDown: {bandwidthDownOctets}",
    "tooltip-format-disconnected": "Disconnected",
    "tooltip-format": "󰩟  {ipaddr}\n󱀣  {netmask} ({cidr})\n\nUp: {bandwidthUpOctets}\nDown: {bandwidthDownOctets}",
    "on-click": "swaymsg exec '$term -e nmtui'",
    "format-icons": ["󰤟", "󰤢", "󰤥", "󰤨", "󰤨"]
  },
{% endfor %}
  "clock": {
    "format": "{:%d/%m %H:%M}",
    "format-alt": "{:%e %b %Y %H:%M:%S}",
    "interval": 5,
{% if waybar_current_version.split('.') | map('int') | list >= [0, 9, 19] %}
    "tooltip": true,
    "tooltip-format": "<tt><span size='9pt'>{calendar}</span></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "", // No week number
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    }
{% endif %}
  },
  "custom/wf-recorder": {
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "format": "{text}",
{% else %}
    "format": "{}",
{% endif %}
    "return-type": "json",
    "interval": 1,
    "tooltip-format": "{tooltip}",
    "exec": "echo '{\"class\": \"recording\",\"text\":\" \",\"tooltip\":\"press Mod+Esc to stop recording\"}'",
    "exec-if": "/usr/bin/pgrep wf-recorder",
    "on-click": "killall --signal SIGINT wf-recorder"
  },
  "custom/playerctl": {
    "interval": "once",
    "tooltip": true,
    "return-type": "json",
    "format": "{icon}",
    "format-icons": {
      "Playing": "",
      "Paused": ""
    },
    "exec": "playerctl metadata --format '{\"alt\": \"{% raw %}{{status}}{% endraw %}\", \"tooltip\": \"{% raw %}{{playerName}}{% endraw %}:  {% raw %}{{markup_escape(title)}}{% endraw %} - {% raw %}{{markup_escape(artist)}}\{% endraw %}" }'",
    "on-click": "playerctl play-pause; pkill -RTMIN+5 waybar",
    "on-click-right": "playerctl next; pkill -RTMIN+5 waybar",
    "on-scroll-up": "playerctl position 10+; pkill -RTMIN+5 waybar",
    "on-scroll-down": "playerctl position 10-; pkill -RTMIN+5 waybar",
    "signal": 5
  },
  "custom/power": {
    "format": " ",
    "on-click": "~/.config/sway/scripts/powermenu.sh"
  },
  "custom/weather": {
    "icon-size": 42,
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "format": "{text} <span font-family='Noto Color Emoji'>{icon}</span>",
{% else %}
    "format": "{} <span font-family='Noto Color Emoji'>{icon}</span>",
{% endif %}
    "tooltip": true,
    "interval": 3600,
    "exec": "~/.config/waybar/scripts/.venv/bin/python ~/.config/waybar/scripts/weather.py --city=Paris --temperature=C",
    "return-type": "json",
    "format-icons": {
      "Unknown": "✨",
      "Cloudy": "☁️",
      "Fog": "🌫",
      "HeavyRain": "🌧",
      "HeavyShowers": "🌧",
      "HeavySnow": "❄️",
      "HeavySnowShowers": "❄️",
      "LightRain": "🌦",
      "LightShowers": "🌦",
      "LightSleet": "🌧",
      "LightSleetShowers": "🌧",
      "LightSnow": "🌨",
      "LightSnowShowers": "🌨",
      "PartlyCloudy": "⛅️",
      "Sunny": "☀️",
      "ThunderyHeavyRain": "🌩",
      "ThunderyShowers": "⛈",
      "ThunderySnowShowers": "⛈",
      "VeryCloudy": "☁️",
    }
  },
  "custom/updates": {
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "format": "{text}",
{% else %}
    "format": "{}",
{% endif %}
    "tooltip": true,
    "interval": 300,
    "exec": "~/.config/waybar/scripts/updates.sh",
    "return-type": "json"
  },
  "inhibitor": {
    "what": ["idle"],
    "format": "{icon}",
    "format-icons": {
      "activated": " ",
      "deactivated": " "
    },
    "tooltip": false
  },
{% if waybar_current_version.split('.') | map('int') | list >= [0, 10, 0] %}
  "systemd-failed-units": {
    "hide-on-ok": true,
    "format": "✗ {nr_failed}",
    "format-ok": "✓",
    "system": true,
    "user": true
  },
{% endif %}
  "privacy": {
    "icon-spacing": 4,
    "icon-size": 18,
    "transition-duration": 250,
    "modules": [
      {
        "type": "screenshare",
        "tooltip": true,
        "tooltip-icon-size": 24
      },
      {
        "type": "audio-out",
        "tooltip": true,
        "tooltip-icon-size": 24
      },
      {
        "type": "audio-in",
        "tooltip": true,
        "tooltip-icon-size": 24
      }
    ]
  },
  "custom/battery": {
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "format": "{icon}  {text}",
{% else %}
    "format": "{icon}  {}",
{% endif %}
    "format-icons": ["", "", "", "", ""],
    "tooltip": true,
    "interval": 60,
    "exec": "~/.config/waybar/scripts/.venv/bin/python ~/.config/waybar/scripts/battery_combined.py",
    "exec-if": "[ -e /sys/class/power_supply/BAT0 ]",
    "return-type": "json"
  },
  "cpu": {
    "interval": 5,
    "format": "  {usage:>3}%",
    "states": {
      "warning": 70,
      "critical": 90
    },
    "on-click": "swaymsg exec '$term -e htop'"
  },
  "memory": {
    "interval": 30,
    "format": "  {percentage:>3}%",
    "states": {
      "warning": 70,
      "critical": 90
    },
    "on-click": "swaymsg exec '$term -e htop'",
{% if waybar_current_version.split('.') | map('int') | list >= [0, 9, 10] %}
    "tooltip-format": "RAM: {used:0.1f} / {total:0.1f} Gb\nSWAP: {swapUsed:0.1f} / {swapTotal:0.1f} Gb"
{% elif waybar_current_version.split('.') | map('int') | list >= [0, 9, 4] %}
    "tooltip-format": "RAM: {used:0.1f} / {total:0.1f} Gb"
{% endif %}
  },
  "tray": {
    "icon-size": 16,
    "spacing": 10
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": " ",
      "performance": " ",
      "balanced": " ",
      "balanced-battery": " ",
      "power-saver": " "
    }
  },
  "custom/tuned": {
    "interval": 60,
    "tooltip": true,
    "return-type": "json",
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "format": "{text}",
{% else %}
    "format": "{}",
{% endif %}
    "exec": "~/.config/sway/scripts/tuned-switcher.sh get",
    "on-click": "~/.config/sway/scripts/tuned-switcher.sh switch",
    "exec-if": "~/.config/sway/scripts/tuned-switcher.sh check",
    "signal": 7
  },
  "hyprland/language": {
    "format": "  {short}"
  },
  "hyprland/workspaces": {
    "all-outputs": false,
    "format": "{icon}  {name}",
    "format-icons": {
      "term": "",
      "dev": "",
      "web": "",
      "mail": "󰇮",
      "message": "",
      "spotify": "",
      "docker": "",
      "passwords": "",
      "zoom": "",
      "default": "󰌽"
    }
  },
  "bluetooth": {
    "format-no-controller": "",
    "tooltip-format-no-controller": "No controller available",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "format-connected": "<span color='#0082fc'>󰂱 </span> {num_connections}",
    "format-on": "<span color='#0082fc'>󰂱 </span> on",
    "format-off": "<span color='#ff0000'>󰂱 </span> off",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "format-disabled": "󰂲",
    "tooltip-format-disabled": "Bluetooth disabled",
    "on-click": "~/.config/waybar/scripts/bluetooth.sh toggle_power",
    "on-click-right": "~/.config/waybar/scripts/bluetooth.sh toggle_status"
  },
  "custom/ncspot": {
    "interval": 5,
    "tooltip": true,
    "return-type": "json",
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "format": "{icon}  {text}",
{% else %}
    "format": "{icon}  {}",
{% endif %}
    "format-icons": {
      "play": "",
      "pause": "",
      "stop": ""
    },
    "exec": "~/.config/waybar/scripts/.venv/bin/python ~/.config/waybar/scripts/ncspot-player.py",
    "exec-if": "pgrep ncspot",
    "exec-on-event": true,
    "on-click": "~/.config/waybar/scripts/.venv/bin/python ~/.config/waybar/scripts/ncspot-player.py toggleplay"
  },
  "custom/media": {
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "format": "{icon}  {text}",
{% else %}
    "format": "{icon}  {}",
{% endif %}
    "tooltip": true,
    "return-type": "json",
    "max-length": 40,
    "format-icons": {
      "spotify": "",
      "spotify_player": "",
      "default": "🎜"
    },
    "escape": false,
    // Filter player based on name
    "exec": "~/.config/waybar/scripts/.venv/bin/python ~/.config/waybar/scripts/mediaplayer.py --player spotify_player",
    "on-click": "playerctl --player=spotify_player play-pause"
  },
  "custom/disk_aio": {
	"interval": 30,
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "format": "{text}",
{% else %}
    "format": "{}",
{% endif %}
    "tooltip": true,
    "return-type": "json",
    "escape": false,
    // Filter player based on name
    "exec": "~/.config/waybar/scripts/.venv/bin/python ~/.config/waybar/scripts/disk_aio.py {% for mount in ansible_facts.mounts|selectattr('fstype','in','ext4,vfat,btrfs')|sort(attribute='mount') %}{{ mount.mount }} {% endfor %}",
  },
  "temperature": {
    "interval": 5,
    "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
    "input-filename": "temp1_input",
    "format": " {temperatureC:>3}°C",
    "critical-threshold": 85,
    "format-critical": " {temperatureC:>3}°C",
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "warning-threshold": 75,
    "format-warning": " {temperatureC:>3}°C",
{% endif %}
    "tooltip": false
  },
  "custom/notification": {
    "tooltip": true,
    "format": "{icon} ",
    "format-icons": {
      "notification": "",
      "none": "",
      "dnd-notification": "",
      "dnd-none": "",
      "inhibited-notification": "",
      "inhibited-none": "",
      "dnd-inhibited-notification": "",
      "dnd-inhibited-none": "",
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  }
}
