    "tooltip-format": "{tooltip}",
    "exec": "echo '{\"class\": \"recording\",\"text\":\"’ĆĮ \",\"tooltip\":\"press Mod+Esc to stop recording\"}'",
    "exec-if": "/usr/bin/pgrep wf-recorder",
    "on-click": "killall --signal SIGINT wf-recorder"
