{
  "sway/workspaces": {
    "all-outputs": false,
    "disable-scroll": false,
    "format": "{icon}  {name}",
    "format-icons": {
      "1:term": "ΎΕι",
      "2:dev": "ΎΞψ",
      "3:web": "ΎΚσ",
      "4:mail": "≤░Θχ",
      "5:message": "ΎΚ║",
      "6:spotify": "ΎΗ╝",
      "8:docker": "ΎΙθ",
      "9:passwords": "ΎΑμ",
      "10:zoom": "ΎΑ░",
      "default": "≤░Ν╜"
    }
  },
  "sway/language": {
    "format": "ΎΕε  {short}",
    "min-length": 5,
    "tooltip": false,
    "on-click": "swaymsg input $(swaymsg -t get_inputs --raw | jq '[.[] | select(.type == \"keyboard\")][0] | .identifier') xkb_switch_layout next"
  },
  "sway/mode": {
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "format": "<span style=\"italic\">{text}</span>",
{% else %}
    "format": "<span style=\"italic\">{}</span>",
{% endif %}
    "tooltip": false
  },
  "sway/window": {
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "format": "{text}",
{% else %}
    "format": "{}",
{% endif %}
    "max-length": 50,
    "tooltip": true
  },
  "sway/scratchpad": {
    "format": "{icon} {count}",
    "show-empty": false,
    "format-icons": ["", "ΎΜΤ "],
    "tooltip": true,
    "tooltip-format": "{app}: {title}"
  },
  "custom/sunset": {
    "interval": "once",
    "tooltip": true,
    "return-type": "json",
    "format": "{icon}",
    "format-icons": {
      "activated": "<span color='#eba0ac'>≤░Ν╡</span>",
      "deactivated": "≤░Ν╢"
    },
    "exec": "fallback_latitude=48.8 fallback_longitude=2.3 latitude= longitude= ~/.config/waybar/scripts/sunset.sh",
    "on-click": "~/.config/waybar/scripts/sunset.sh toggle",
    "exec-if": "~/.config/waybar/scripts/sunset.sh check",
    "signal": 6
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon}  {percent:>3}%",
    "format-icons": ["≤░╣Ρ", "≤▒σΟ", "≤▒σΠ", "≤▒σΡ", "≤▒σΣ", "≤▒σΤ", "≤▒σΥ", "≤▒σΦ", "≤▒σΧ", "≤▒σΨ", "≤░δρ"],
{% if waybar_current_version.split('.') | map('int') | list >= [0, 9, 18] %}
    "scroll-step": 5.0,
{% else %}
    "on-scroll-down": "brightnessctl --quiet set 5%-",
    "on-scroll-up": "brightnessctl --quiet set 5%+"
{% endif %}
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "min-brightness": 5.0,
{% endif %}
  },
  "pulseaudio": {
    "format": "{icon} {volume:>3}% {format_source}",
    "format-bluetooth": "{icon}ΎΛΥ {volume:>3}%",
    "format-muted": "ΎΑο mute {format_source}",
    "format-source": "ΎΕ░ {volume:>3}%",
    "format-source-muted": "ΎΕ▒ mute",
    "format-icons": {
      "headphone": "ΎΑξ",
      "alsa_output.usb-Kingston_HyperX_Virtual_Surround_Sound_00000000-00.analog-stereo": "≤░ΜΟ",
      "alsa_output.usb-Kingston_HyperX_Cloud_II_Wireless_000000000001-00.analog-surround-71": "≤░ΜΟ",
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
    "tooltip-format": "{desc}:έΑΛ{volume}% {format_source}",
    "on-click": "swaymsg exec '$volume_mute'",
    "on-click-right": "swaymsg exec 'pavucontrol'"
  },
{% for interface in ansible_facts | dict2items | selectattr('value.module', 'defined') | map(attribute='value') | list | sort(attribute='device') %}
  "network#{{ interface.device }}": {
    "interface": "{{ interface.device }}",
    "format-wifi": "{icon}  {ifname}: {ipaddr}",
    "format-ethernet": "ΎΔΒ  {ifname}: {ipaddr}",
    "format-disconnected": "ΎΕπ  {ifname}",
    "tooltip-format-wifi": "Connected on {essid} (Freq: {frequency})\nSignal: {signalStrength}\n\n≤░σθ  {ipaddr}\n≤▒Αμ  {netmask} ({cidr})\n≤▒ΓΘ  {gwaddr}\n\nUp: {bandwidthUpOctets}\nDown: {bandwidthDownOctets}",
    "tooltip-format-disconnected": "Disconnected",
    "tooltip-format": "≤░σθ  {ipaddr}\n≤▒Αμ  {netmask} ({cidr})\n≤▒ΓΘ  {gwaddr}\n\nUp: {bandwidthUpOctets}\nDown: {bandwidthDownOctets}",
    "on-click": "swaymsg exec '$term -e nmtui'",
    "format-icons": ["≤░νθ", "≤░νλ", "≤░νξ", "≤░νρ", "≤░νρ"]
  },
{% endfor %}
  "clock": {
    "format": "{:%d/%m %H:%M}",
    "format-alt": "{:%e %b %Y %H:%M:%S}",
    "interval": 5,
{% if waybar_current_version.split('.') | map('int') | list >= [0, 9, 19] %}
    "tooltip": true,
    "tooltip-format": "<tt><span size='9pt'>{calendar}</span></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "", // No week number
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    }
{% endif %}
  },
  "custom/wf-recorder": {
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "format": "{text}",
{% else %}
    "format": "{}",
{% endif %}
    "return-type": "json",
    "interval": 1,
    "tooltip-format": "{tooltip}",
    "exec": "echo '{\"class\": \"recording\",\"text\":\"ΎΑ╜ \",\"tooltip\":\"press Mod+Esc to stop recording\"}'",
    "exec-if": "/usr/bin/pgrep wf-recorder",
    "on-click": "killall --signal SIGINT wf-recorder"
  },
  "custom/playerctl": {
    "interval": "once",
    "tooltip": true,
    "return-type": "json",
    "format": "{icon}",
    "format-icons": {
      "Playing": "ΎΒΜ",
      "Paused": "ΎΒΝ"
    },
    "exec": "playerctl metadata --format '{\"alt\": \"{% raw %}{{status}}{% endraw %}\", \"tooltip\": \"{% raw %}{{playerName}}{% endraw %}:  {% raw %}{{markup_escape(title)}}{% endraw %} - {% raw %}{{markup_escape(artist)}}\{% endraw %}" }'",
    "on-click": "playerctl play-pause; pkill -RTMIN+5 waybar",
    "on-click-right": "playerctl next; pkill -RTMIN+5 waybar",
    "on-scroll-up": "playerctl position 10+; pkill -RTMIN+5 waybar",
    "on-scroll-down": "playerctl position 10-; pkill -RTMIN+5 waybar",
    "signal": 5
  },
  "custom/power": {
    "format": "ΎΑΣ ",
    "on-click": "~/.config/sway/scripts/powermenu.sh"
  },
  "custom/weather": {
    "icon-size": 42,
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "format": "{text} <span font-family='Noto Color Emoji'>{icon}</span>",
{% else %}
    "format": "{} <span font-family='Noto Color Emoji'>{icon}</span>",
{% endif %}
    "tooltip": true,
    "interval": 3600,
    "exec": "~/.config/waybar/scripts/.venv/bin/python ~/.config/waybar/scripts/weather.py --city=Paris --temperature=C",
    "return-type": "json",
    "format-icons": {
      "Unknown": "έερ",
      "Cloudy": "έαΒΎ╕Π",
      "Fog": "ΏθΝτ",
      "HeavyRain": "ΏθΝπ",
      "HeavyShowers": "ΏθΝπ",
      "HeavySnow": "έζΕΎ╕Π",
      "HeavySnowShowers": "έζΕΎ╕Π",
      "LightRain": "ΏθΝο",
      "LightShowers": "ΏθΝο",
      "LightSleet": "ΏθΝπ",
      "LightSleetShowers": "ΏθΝπ",
      "LightSnow": "ΏθΝρ",
      "LightSnowShowers": "ΏθΝρ",
      "PartlyCloudy": "έδΖΎ╕Π",
      "Sunny": "έαΑΎ╕Π",
      "ThunderyHeavyRain": "ΏθΝσ",
      "ThunderyShowers": "έδΙ",
      "ThunderySnowShowers": "έδΙ",
      "VeryCloudy": "έαΒΎ╕Π",
    }
  },
  "custom/updates": {
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "format": "{text}",
{% else %}
    "format": "{}",
{% endif %}
    "tooltip": true,
    "interval": 300,
    "exec": "~/.config/waybar/scripts/updates.sh",
    "return-type": "json"
  },

  "custom/idle_inhibitor": {
    "interval": 60,
    "return-type": "json",
    "format": "{icon}",
    "format-icons": {
      "activated": "ΎΒχ ",
      "deactivated": "ΎΒ░ "
    },
    "exec": "~/.config/sway/scripts/inhibit-idle.sh",
    "exec-if": "~/.config/sway/scripts/inhibit-idle.sh check",
    "on-click": "~/.config/sway/scripts/inhibit-idle.sh off; ~/.config/sway/scripts/inhibit-idle.sh interactive",
    "on-click-middle": "~/.config/sway/scripts/inhibit-idle.sh off",
    "signal": 15
  },
  "systemd-failed-units": {
    "hide-on-ok": true,
    "format": "έεΩ {nr_failed}",
    "format-ok": "έεΥ",
    "system": true,
    "user": true
  },
  "privacy": {
    "icon-spacing": 4,
    "icon-size": 18,
    "transition-duration": 250,
    "modules": [
      {
        "type": "screenshare",
        "tooltip": true,
        "tooltip-icon-size": 24
      },
      {
        "type": "audio-out",
        "tooltip": true,
        "tooltip-icon-size": 24
      },
      {
        "type": "audio-in",
        "tooltip": true,
        "tooltip-icon-size": 24
      }
    ]
  },
  "custom/battery": {
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "format": "{icon}  {text}",
{% else %}
    "format": "{icon}  {}",
{% endif %}
    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
    "tooltip": true,
    "interval": 60,
    "exec": "~/.config/waybar/scripts/.venv/bin/python ~/.config/waybar/scripts/battery_combined.py",
    "exec-if": "[ -e /sys/class/power_supply/BAT0 ]",
    "return-type": "json"
  },
  "cpu": {
    "interval": 5,
    "format": "ΎΤ╝  {usage:>2}%",
    "states": {
      "warning": 70,
      "critical": 90
    },
    "on-click": "swaymsg exec '$term -e htop'"
  },
  "memory": {
    "interval": 30,
    "format": "Ό┐Ζ  {percentage:>2}%",
    "states": {
      "warning": 70,
      "critical": 90
    },
    "on-click": "swaymsg exec '$term -e htop'",
{% if waybar_current_version.split('.') | map('int') | list >= [0, 9, 10] %}
    "tooltip-format": "RAM: {used:0.1f} / {total:0.1f} Gb\nSWAP: {swapUsed:0.1f} / {swapTotal:0.1f} Gb"
{% elif waybar_current_version.split('.') | map('int') | list >= [0, 9, 4] %}
    "tooltip-format": "RAM: {used:0.1f} / {total:0.1f} Gb"
{% endif %}
  },
  "tray": {
    "icon-size": 16,
    "spacing": 10
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "ΎΔπ ",
      "performance": "ΎΔπ ",
      "balanced": "ΎΚΟ ",
      "power-saver": "ΎΒυ "
    }
  },
  "custom/tuned": {
    "interval": 60,
    "tooltip": true,
    "return-type": "json",
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "format": "{text}",
{% else %}
    "format": "{}",
{% endif %}
    "exec": "~/.config/waybar/scripts/tuned-switcher.sh get",
    "on-click": "~/.config/waybar/scripts/tuned-switcher.sh switch",
    "exec-if": "~/.config/waybar/scripts/tuned-switcher.sh check",
    "signal": 7
  },
  "hyprland/language": {
    "format": "ΎΕε  {short}"
  },
  "hyprland/workspaces": {
    "all-outputs": false,
    "format": "{icon}  {name}",
    "format-icons": {
      "term": "ΎΕι",
      "dev": "ΎΞψ",
      "web": "ΎΚσ",
      "mail": "≤░Θχ",
      "message": "ΎΚ║",
      "spotify": "ΎΗ╝",
      "docker": "ΎΙθ",
      "passwords": "ΎΑμ",
      "zoom": "ΎΑ░",
      "default": "≤░Ν╜"
    }
  },
  "bluetooth": {
    "format-no-controller": "",
    "tooltip-format-no-controller": "No controller available",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "format-connected": "<span color='#0082fc'>≤░Γ▒ </span> {num_connections}",
    "format-on": "<span color='#0082fc'>≤░Γ▒ </span> on",
    "format-off": "<span color='#ff0000'>≤░Γ▒ </span> off",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "format-disabled": "≤░Γ▓",
    "tooltip-format-disabled": "Bluetooth disabled",
    "on-click": "~/.config/waybar/scripts/bluetooth.sh toggle_power",
    "on-click-right": "~/.config/waybar/scripts/bluetooth.sh toggle_status"
  },
  "custom/ncspot": {
    "interval": 5,
    "tooltip": true,
    "return-type": "json",
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "format": "{icon}  {text}",
{% else %}
    "format": "{icon}  {}",
{% endif %}
    "format-icons": {
      "play": "ΎΒΜ",
      "pause": "ΎΒΝ",
      "stop": "ΎΒΞ"
    },
    "exec": "~/.config/waybar/scripts/.venv/bin/python ~/.config/waybar/scripts/ncspot-player.py",
    "exec-if": "pgrep ncspot",
    "exec-on-event": true,
    "on-click": "~/.config/waybar/scripts/.venv/bin/python ~/.config/waybar/scripts/ncspot-player.py toggleplay"
  },
  "custom/media": {
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "format": "{icon}  {text}",
{% else %}
    "format": "{icon}  {}",
{% endif %}
    "tooltip": true,
    "return-type": "json",
    "max-length": 40,
    "format-icons": {
      "spotify": "ΎΗ╝",
      "spotify_player": "ΎΗ╝",
      "default": "ΏθΟε"
    },
    "escape": false,
    // Filter player based on name
    "exec": "~/.config/waybar/scripts/.venv/bin/python ~/.config/waybar/scripts/mediaplayer.py --player spotify_player",
    "on-click": "playerctl --player=spotify_player play-pause"
  },
  "custom/disk_aio": {
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "format": "{text}",
{% else %}
    "tooltip": true,
{% endif %}
    "return-type": "json",
    "escape": false,
    // Filter player based on name
    "exec": "~/.config/waybar/scripts/.venv/bin/python ~/.config/waybar/scripts/disk_aio.py {% for mount in ansible_mounts|selectattr('fstype','in','ext4,vfat')|sort(attribute='mount') %}{{ mount.mount }} {% endfor %}",
  },
  "temperature": {
    "interval": 5,
    "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
    "input-filename": "temp1_input",
    "format": "ΎΜΜ {temperatureC}┬░C",
    "critical-threshold": 85,
    "format-critical": "ΎΜΘ {temperatureC}┬░C",
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "warning-threshold": 75,
    "format-warning": "ΎΜΚ {temperatureC}┬░C",
{% endif %}
    "tooltip": false
  }
}
