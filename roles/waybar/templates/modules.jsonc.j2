    "on-click": "~/.config/waybar/scripts/bluetooth.sh toggle_power",
    "on-click-right": "~/.config/waybar/scripts/bluetooth.sh toggle_status"
  },
  "custom/ncspot": {
    "interval": 5,
    "tooltip": true,
    "return-type": "json",
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "format": "{icon}  {text}",
{% else %}
    "format": "{icon}  {}",
{% endif %}
    "format-icons": {
      "play": "´üő",
      "pause": "´üî",
      "stop": "´üŹ"
    },
    "exec": "~/.config/waybar/scripts/.venv/bin/python ~/.config/waybar/scripts/ncspot-player.py",
    "exec-if": "pgrep ncspot",
    "exec-on-event": true,
    "on-click": "~/.config/waybar/scripts/.venv/bin/python ~/.config/waybar/scripts/ncspot-player.py toggleplay"
  },
  "custom/media": {
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "format": "{icon}  {text}",
{% else %}
    "format": "{icon}  {}",
{% endif %}
    "tooltip": true,
    "return-type": "json",
    "max-length": 40,
    "format-icons": {
      "spotify": "´ć╝",
      "spotify_player": "´ć╝",
      "default": "­čÄť"
    },
    "escape": false,
    // Filter player based on name
    "exec": "~/.config/waybar/scripts/.venv/bin/python ~/.config/waybar/scripts/mediaplayer.py --player spotify_player",
    "on-click": "playerctl --player=spotify_player play-pause"
  },
  "custom/disk_aio": {
	"interval": 30,
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "format": "{text}",
{% else %}
    "format": "{}",
{% endif %}
    "tooltip": true,
    "return-type": "json",
    "escape": false,
    // Filter player based on name
    "exec": "~/.config/waybar/scripts/.venv/bin/python ~/.config/waybar/scripts/disk_aio.py {% for mount in ansible_mounts|selectattr('fstype','in','ext4,vfat')|sort(attribute='mount') %}{{ mount.mount }} {% endfor %}",
  },
  "temperature": {
    "interval": 5,
    "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
    "input-filename": "temp1_input",
    "format": "´őő {temperatureC:>3}┬░C",
    "critical-threshold": 85,
    "format-critical": "´őç {temperatureC:>3}┬░C",
{% if waybar_current_version.split('.') | map('int') | list >= [0, 12, 0] %}
    "warning-threshold": 75,
    "format-warning": "´őë {temperatureC:>3}┬░C",
{% endif %}
    "tooltip": false
  }
}
