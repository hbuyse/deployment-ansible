[Unit]
Description=wlsunset - Day/night gamma adjustments for Wayland compositors supporting wlr-gamma-control-unstable-v1
Documentation=man:wlsunset(1)
PartOf=sway-session.target
After=sway-session.target

[Service]
Type=simple
ExecStart=/usr/bin/wlsunset -l {{ wlsunset_config.latitude }} -L {{ wlsunset_config.longitude }}
{%- if wlsunset_config.temp_low %}
  -t {{ wlsunset_config.temp_low }}
{%- endif %}
{% if wlsunset_config.temp_high %}
  -T {{ wlsunset_config.temp_high }}
{%- endif %}
{% if wlsunset_config.duration %}
  -d {{ wlsunset_config.duration }}
{% endif %}
Restart=on-failure
RestartSec=5

[Install]
WantedBy=sway-session.target
